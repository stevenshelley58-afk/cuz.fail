{
	admin off
	auto_https off
}

(security_headers) {
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
	}
}

(api_routes) {
	@api_uploads path /api/v1/documents/*/upload /api/v1/sources/import
	request_body @api_uploads {
		max_size 250MB
	}
	handle /api/v1* {
		reverse_proxy api:8000
	}
}

http://api.cuz.fail {
	import security_headers
	encode zstd gzip
	import api_routes
	handle {
		respond "not found" 404
	}
}

http://cuz.fail {
	import security_headers
	redir https://lotfile.app{uri} permanent
}

http://www.cuz.fail {
	import security_headers
	redir https://lotfile.app{uri} permanent
}

http://app.cuz.fail {
	import security_headers
	redir https://lotfile.app{uri} permanent
}

http://lotfile.app {
	import security_headers
	encode zstd gzip
	import api_routes
	handle {
		root * /srv/draftcheck/app/web/dist
		try_files {path} {path}/index.html /index.html
		file_server
	}
}
