{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ExtractRulesOutput",
  "type": "object",
  "required": ["rule_key", "operator", "value_json", "unit", "condition_json", "quote", "rule_type", "confidence"],
  "properties": {
    "rule_key": {"type": "string"},
    "operator": {
      "type": "string",
      "enum": ["lte", "gte", "eq", "lt", "gt", "range", "pct_lte", "pct_gte"]
    },
    "value_json": {"type": ["number", "object", "null"]},
    "unit": {"type": ["string", "null"]},
    "condition_json": {"type": ["object", "null"]},
    "quote": {"type": "string", "minLength": 5},
    "rule_type": {
      "type": "string",
      "enum": ["standard", "exception", "deemed_to_comply", "design_principle"]
    },
    "pathway": {"type": ["string", "null"]},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1}
  },
  "additionalProperties": false
}
