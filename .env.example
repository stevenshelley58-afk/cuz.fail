DATABASE_URL=postgresql+psycopg://draftcheck:local@127.0.0.1:5432/draftcheck
REQUIRE_DURABLE_DATABASE=false
OBJECT_STORAGE_ROOT=.storage
API_HOST=127.0.0.1
API_PORT=8000
UPLOAD_MAX_BYTES=26214400
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_CHAT_REQUESTS=120
RATE_LIMIT_UPLOAD_REQUESTS=20
API_AUTH_ENABLED=false
# Production requires tenant scoping and key values at least 32 characters long:
# API_AUTH_KEYS=tenant-a:long-random-key,tenant-b:another-long-random-key
# A bare key is accepted for local/dev compatibility and maps to tenant "default".
API_AUTH_KEYS=
CORS_ALLOWED_ORIGINS=*

# Dev-only username/password login (POST /auth/dev-login).
# Hard-disabled in production by app_env (see src/draftcheck/api/auth.py).
DEV_LOGIN_USERNAME=jemma
DEV_LOGIN_PASSWORD=jemma6969

# Magic-link email delivery. Local/dev logs links when SMTP_HOST is empty.
# Production returns 503 for magic-link requests until SMTP_HOST and SMTP_FROM are set.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_FROM_NAME=LotFile
SMTP_STARTTLS=true
SMTP_SSL=false
SMTP_TIMEOUT_SECONDS=10

HERMES_ENABLED=false
HERMES_BASE_URL=
HERMES_API_KEY=
HERMES_MAX_CONCURRENCY=4
HERMES_DEFAULT_MODEL=cheap-extraction-model
HERMES_REVIEW_MODEL=strong-review-model
HERMES_TIMEOUT_MS=30000

LLM_PROVIDER=mock
# Set LLM_PROVIDER=openai and OPENAI_API_KEY to enable the live grounded assistant (gpt-4o).
# Set LLM_PROVIDER=openrouter and OPENROUTER_API_KEY to use OpenRouter instead.
# Without a key the assistant falls back to the deterministic cite-or-refuse engine.
LLM_MODEL=MiniMax-M3
LLM_TIMEOUT_SECONDS=30
LLM_MAX_OUTPUT_TOKENS=1200
EMBEDDING_PROVIDER=mock
# EMBEDDING_PROVIDER=openai requires OPENAI_API_KEY and a rebuild of source chunk embeddings.
EMBEDDING_MODEL=
EMBEDDING_DIMENSIONS=0
EMBEDDING_TIMEOUT_SECONDS=30
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=https://app.cuz.fail
OPENROUTER_APP_NAME=LotFile
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.chat/v1
BOOTSTRAP_DEMO_SOURCE_LIBRARY=false
