DATABASE_URL=sqlite:///./draftcheck.db
REQUIRE_DURABLE_DATABASE=false
REQUIRE_DURABLE_OBJECT_STORAGE=false
OBJECT_STORAGE_ROOT=.storage
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_RAW_SOURCES=raw-sources
S3_BUCKET_PARSED_SOURCES=parsed-sources
S3_BUCKET_UPLOADS=uploads
S3_BUCKET_EXPORTS=exports
API_HOST=127.0.0.1
API_PORT=8000
UPLOAD_MAX_BYTES=26214400
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_CHAT_REQUESTS=120
RATE_LIMIT_UPLOAD_REQUESTS=20
API_AUTH_ENABLED=false
# Production requires tenant scoping and key values at least 32 characters long:
# API_AUTH_KEYS=tenant-a:long-random-key,tenant-b:another-long-random-key
# A bare key is accepted for local/dev compatibility and maps to tenant "default".
API_AUTH_KEYS=
CORS_ALLOWED_ORIGINS=*

HERMES_ENABLED=false
HERMES_BASE_URL=
HERMES_API_KEY=
HERMES_MAX_CONCURRENCY=4
HERMES_DEFAULT_MODEL=cheap-extraction-model
HERMES_REVIEW_MODEL=strong-review-model
HERMES_TIMEOUT_MS=30000

RQ_ENABLED=false
RQ_REDIS_URL=redis://localhost:6379/0
RQ_DEFAULT_QUEUE=default
RQ_QUEUES=default,source_ingestion,council_pack,rfi_analysis,source_freshness_audit
RQ_JOB_TIMEOUT_SECONDS=300
RQ_RETRY_MAX=1
RQ_RETRY_INTERVAL_SECONDS=30
RQ_SOCKET_CONNECT_TIMEOUT_SECONDS=1
RQ_SOCKET_TIMEOUT_SECONDS=1
RQ_WORKER_BURST=false

LLM_PROVIDER=mock
# Set LLM_PROVIDER=openai and OPENAI_API_KEY to enable the live grounded assistant.
# Without a key the assistant falls back to the deterministic cite-or-refuse engine.
LLM_MODEL=gpt-5.5
LLM_TIMEOUT_SECONDS=30
LLM_MAX_OUTPUT_TOKENS=700
EMBEDDING_PROVIDER=mock
# EMBEDDING_PROVIDER=openai requires OPENAI_API_KEY and a rebuild of source chunk embeddings.
EMBEDDING_MODEL=
EMBEDDING_DIMENSIONS=0
EMBEDDING_TIMEOUT_SECONDS=30
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
BOOTSTRAP_DEMO_SOURCE_LIBRARY=false
