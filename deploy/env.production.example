# Copy to deploy/.env and fill in. Never commit deploy/.env.

# Supabase Postgres. Two options:
#
# 1) Session pooler (RECOMMENDED — works on IPv4-only VPSes).
#    Exact host shown in Supabase Dashboard -> Connect -> Session pooler.
#    Note the username carries the project ref:
# DATABASE_URL=postgresql+psycopg://postgres.jcjjfuqvbtcbidmdjbhy:YOUR_DB_PASSWORD@<pooler-host>:5432/postgres
#
# 2) Direct connection (requires IPv6 on the VPS):
# DATABASE_URL=postgresql+psycopg://postgres:YOUR_DB_PASSWORD@db.jcjjfuqvbtcbidmdjbhy.supabase.co:5432/postgres

DATABASE_URL=postgresql+psycopg://postgres.jcjjfuqvbtcbidmdjbhy:YOUR_DB_PASSWORD@CHANGE_ME.pooler.supabase.com:5432/postgres

OBJECT_STORAGE_ROOT=/app/.storage

HERMES_ENABLED=false
HERMES_BASE_URL=
HERMES_API_KEY=
HERMES_MAX_CONCURRENCY=4
HERMES_DEFAULT_MODEL=cheap-extraction-model
HERMES_REVIEW_MODEL=strong-review-model
HERMES_TIMEOUT_MS=30000

LLM_PROVIDER=mock
EMBEDDING_PROVIDER=mock
