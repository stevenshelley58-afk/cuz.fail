# Copy to deploy/.env and fill in. Never commit deploy/.env.

POSTGRES_USER=draftcheck
POSTGRES_PW=
POSTGRES_DB=draftcheck

MINIO_ROOT_USER=draftcheck
MINIO_ROOT_PW=

CADDY_API_HOST=api.cuz.fail
CADDY_APP_HOST=app.cuz.fail
STATIC_FRONTEND_ROOT=/srv/cuz-frontend
CORS_ALLOWED_ORIGINS=https://app.cuz.fail
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_CHAT_REQUESTS=120
RATE_LIMIT_UPLOAD_REQUESTS=20

# Required for production magic-link email delivery.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_FROM_NAME=LotFile
SMTP_STARTTLS=true
SMTP_SSL=false
SMTP_TIMEOUT_SECONDS=10

HERMES_ENABLED=false
HERMES_BASE_URL=
HERMES_API_KEY=
HERMES_MAX_CONCURRENCY=4
HERMES_DEFAULT_MODEL=cheap-extraction-model
HERMES_REVIEW_MODEL=strong-review-model
HERMES_TIMEOUT_MS=30000

RQ_ENABLED=true
RQ_REDIS_URL=redis://redis:6379/0
RQ_DEFAULT_QUEUE=default
RQ_QUEUES=default,source_ingestion,council_pack,rfi_analysis,source_freshness_audit
RQ_JOB_TIMEOUT_SECONDS=300
RQ_RETRY_MAX=1
RQ_RETRY_INTERVAL_SECONDS=30
RQ_SOCKET_CONNECT_TIMEOUT_SECONDS=1
RQ_SOCKET_TIMEOUT_SECONDS=1
RQ_WORKER_BURST=false

LLM_PROVIDER=mock
LLM_MODEL=gpt-5.5
LLM_TIMEOUT_SECONDS=30
LLM_MAX_OUTPUT_TOKENS=700
EMBEDDING_PROVIDER=mock
# Optional semantic retrieval upgrade. After changing these, run scripts/rebuild_source_embeddings.py
# against the durable database before judging retrieval quality.
EMBEDDING_MODEL=
EMBEDDING_DIMENSIONS=0
EMBEDDING_TIMEOUT_SECONDS=30
# Set LLM_PROVIDER=openai with OPENAI_API_KEY, or LLM_PROVIDER=openrouter with OPENROUTER_API_KEY.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=https://app.cuz.fail
OPENROUTER_APP_NAME=LotFile

S3_ACCESS_KEY_ID=draftcheck
S3_SECRET_KEY=
S3_SESSION_TOKEN=
S3_REGION=us-east-1
S3_BUCKET_RAW_SOURCES=raw-sources
S3_BUCKET_PARSED_SOURCES=parsed-sources
S3_BUCKET_UPLOADS=uploads
S3_BUCKET_EXPORTS=exports
